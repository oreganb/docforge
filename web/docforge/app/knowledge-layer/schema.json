{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://docforge.local/knowledge-layer/schema.json",
  "title": "DocForge Knowledge Layer",
  "description": "Knowledge Layer v1.0 contract (PRD §2.2, v5.1 amendment 5)",
  "type": "object",
  "required": ["version", "fingerprint", "title", "source", "blocks", "quality"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "fingerprint": {
      "type": "object",
      "required": ["sha256", "size_bytes", "mime", "source_name"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "mime": { "type": "string" },
        "source_name": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "title": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "pages": { "type": "array" },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": { "type": "string" },
          "text": { "type": "string" },
          "level": { "type": "integer" },
          "location": { "type": "string" }
        }
      }
    },
    "sections": { "type": "array" },
    "tables": { "type": "array" },
    "figures": { "type": "array" },
    "entities": { "type": "array" },
    "references": { "type": "array" },
    "summaries": {
      "type": "object",
      "properties": {
        "short": { "type": "string" },
        "extended": { "type": "string" },
        "key_findings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "keyphrases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phrase", "score"],
        "properties": {
          "phrase": { "type": "string" },
          "score": { "type": "number" }
        }
      }
    },
    "statistics": { "type": "object" },
    "quality": {
      "type": "object",
      "required": ["knowledge_score"],
      "properties": {
        "knowledge_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "sub_scores": { "type": "object" },
        "issues": { "type": "array", "items": { "type": "string" } },
        "verdict": { "type": "string" }
      }
    },
    "provenance": { "type": "array" }
  }
}
