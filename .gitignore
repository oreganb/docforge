.DS_Store
**/.DS_Store

# Internal docs — may contain confidential information (specs, credentials, screenshots)
docs/

# Local-only working material, not needed in the public repo
testiing/
template/

# Deploy credentials — kept locally only, never committed
scripts/.deploy.env

web/docforge/app/vendor/
web/docforge/app/config/config.local.php
web/docforge/storage/uploads-tmp/*
web/docforge/storage/reports/*
web/docforge/storage/logs/*
!web/docforge/storage/uploads-tmp/.gitkeep
!web/docforge/storage/reports/.gitkeep
!web/docforge/storage/logs/.gitkeep

# Word temp lock files
~$*
